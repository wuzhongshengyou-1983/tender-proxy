{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@tender/core": ["./packages/core/src/index.ts"],
      "@tender/core/*": ["./packages/core/src/*"],
      "@tender/auth": ["./packages/auth/src/index.ts"],
      "@tender/auth/*": ["./packages/auth/src/*"],
      "@tender/protocol": ["./packages/protocol/src/index.ts"],
      "@tender/protocol/*": ["./packages/protocol/src/*"],
      "@tender/router": ["./packages/router/src/index.ts"],
      "@tender/router/*": ["./packages/router/src/*"],
      "@tender/audit": ["./packages/audit/src/index.ts"],
      "@tender/audit/*": ["./packages/audit/src/*"],
      "@tender/quota": ["./packages/quota/src/index.ts"],
      "@tender/quota/*": ["./packages/quota/src/*"]
    }
  },
  "include": [
    "packages/*/src/**/*",
    "server/src/**/*",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
