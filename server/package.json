{
  "name": "@tender/server",
  "version": "0.1.0",
  "description": "Tender proxy server - Fastify main process",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@tender/audit": "workspace:*",
    "@tender/auth": "workspace:*",
    "@tender/core": "workspace:*",
    "@tender/protocol": "workspace:*",
    "@tender/quota": "workspace:*",
    "@tender/router": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.2.0",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "license": "Apache-2.0"
}
